# ---------------------------
# Entornos Virtuales Python
# ---------------------------
venv/
.venv/
env/
.env/
backend/venv/
backend/.venv/
ENV/
env.bak/
venv.bak/

# ---------------------------
# Python / Bytecode
# ---------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
*.manifest
*.spec

# ---------------------------
# Pytest / Coverage
# ---------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# ---------------------------
# Django
# ---------------------------
*.sqlite3
db.sqlite3
backend/staticfiles/
backend/static/
backend/media/
backend/logs/
*.log

# ---------------------------
# Variables de Entorno
# ---------------------------
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
.env.prod
.env.local
.env.staging

# ---------------------------
# Jupyter Notebooks
# ---------------------------
.ipynb_checkpoints
*.ipynb

# ---------------------------
# IDE y Editores
# ---------------------------
# VS Code
.vscode/
*.code-workspace

# PyCharm / JetBrains
.idea/
*.iml
*.iws
*.ipr
out/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.\#*

# ---------------------------
# Sistemas Operativos
# ---------------------------
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~

# ---------------------------
# Docker / Bases de Datos
# ---------------------------
postgres_data/
pgdata/
mysql_data/
redis_data/
.dockerignore

# ---------------------------
# Node / Frontend (si aplica)
# ---------------------------
node_modules/
frontend/node_modules/
frontend/dist/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ---------------------------
# Archivos de Datos y Cargas
# ---------------------------
*.xlsx
*.xls
*.csv
!backend/**/fixtures/*.csv
uploads/
media/

# ---------------------------
# Misceláneos
# ---------------------------
*.pid
*.seed
*.pid.lock
.python-version
pip-log.txt
pip-delete-this-directory.txt
