# TireWatch - Variables de Entorno
# Copiar a .env y ajustar valores

# Django
DJANGO_SECRET_KEY=cambiar-por-una-clave-segura-en-produccion
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Base de datos (SQLite por defecto, PostgreSQL para producción)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=tirewatch
# DB_USER=tirewatch_user
# DB_PASSWORD=contraseña_segura
# DB_HOST=localhost
# DB_PORT=5432

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
